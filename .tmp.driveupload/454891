from diffusion_kinetics.optimization.forward_model_kinetics import forwardModelKinetics
from diffusion_kinetics.optimization.forward_model_kinetics import calc_lnd0aa
from diffusion_kinetics.optimization.dataset import Dataset
import math as math
import torch as torch
import numpy as np


class DiffusionObjective:
    """
    Calculates the objective function (misfit) between experimental diffusion data 
    and a Multi-Domain Diffusion (MDD) forward model.
    
    This class handles the transformation of MDD parameters into predicted fractional 
    releases and moles, compares them against observed data using various statistics, 
    and applies penalties for physical inconsistencies (e.g., early degassing).
    """
    
    def __init__(
        self,
        data: Dataset,
        omitValueIndices=[],
        stat: str = "chisq",
        geometry: str = "spherical",
        punish_degas_early: bool = True
    ):
        """
        Initializes the objective function with experimental data and modeling constraints.
        
        Args:
            data (Dataset): The experimental dataset containing temperatures, times, and gas yields.
            omitValueIndices (list): Indices of experimental steps to exclude from misfit calculation.
            stat (str): The misfit statistic to use ('chisq' or 'l1_moles').
            geometry (str): Diffusion geometry ('spherical', 'cylindrical', or 'planar').
            punish_degas_early (bool): If True, heavily penalizes models that exhaust gas before the experiment ends.
        """
        
        # 1. CORE ATTRIBUTES & STATE ENCAPSULATION
        # Storing the dataset and configuration to keep the optimization loop clean
        self.dataset = data
        self.stat = stat
        self.geometry = geometry
        self.punish_degas_early = punish_degas_early
        self._TC = self.dataset._TC
        
        # Convert experimental heating durations from hours to seconds
        self.tsec = self.dataset._thr * 3600
        
        # 2. VECTORIZATION PREP (PYTORCH TENSORS)
        # We cast our targets to PyTorch tensors exactly once during initialization.
        # This prevents expensive type-conversions during the thousands of optimization iterations.
        self.exp_moles = torch.tensor(data.M)
        self.total_moles = torch.sum(self.exp_moles)
        self.total_moles_del = torch.sqrt(torch.sum(torch.tensor(self.dataset.delM) ** 2))
        
        # Calculate non-cumulative fractional release for each heating step
        self.Fi = torch.tensor(data.Fi)
        trueFracFi = self.Fi[1:] - self.Fi[0:-1]
        self.trueFracFi = torch.concat((torch.unsqueeze(self.Fi[0], dim=-0), trueFracFi), dim=-1)

        # 3. BINARY MASK GENERATION FOR FILTERING
        # Create vectorized masks (1s and 0s) to ignore noisy data points during the objective call.
        # This replaces slow Python if/else statements with fast matrix multiplication.
        
        # Standard mask for user-specified omissions
        self.omitValueIndices = torch.isin(
            torch.arange(len(self.dataset)), 
            torch.tensor(omitValueIndices)
        ).to(torch.int)

        # 4. DEFENSIVE DATA SANITIZATION
        # Prevent math domain errors (e.g., dividing by zero in a chi-squared calculation).
        # We identify steps with zero uncertainty and replace them with a fractional baseline.
        data.uncert[data.uncert == 0] = torch.min(data.uncert[data.uncert != 0]) * 0.1

        # Specialized mask for Chi-Squared: dynamically append indices that originally had zero uncertainty
        # This happens in specialized cases where diffusion gas appears to run out in one step, and then reappears in another, higher-T step.
        indices_chisq = np.where(data.uncert == 0)
        omitValueIndices_chisq = omitValueIndices + (indices_chisq[0].tolist())
        
        self.omitValueIndices_chisq = torch.isin(
            torch.arange(len(self.dataset)), 
            torch.tensor(omitValueIndices_chisq)
        ).to(torch.int)


    def __call__(self, X):
        return self.objective(X)

    def grad(self, X):
        return self.grad(X)

    def objective(self, X):
        """
        The core engine: Forward models the physical diffusion kinetics for a set of parameters (X) 
        and calculates the statistical misfit against the observed experimental data.
        """
        if X.size == 0:
            return []

        # 1. PARAMETER EXTRACTION & FORWARD MODELING
        # Extract total moles if X contains an odd number of parameters
        if len(X) % 2 != 0:
            total_moles = X[0]
            X = X[1:]

        # Run the physics engine: forward model the kinetics for thousands of 
        # proposed thermal histories simultaneously using PyTorch.
        Fi_MDD, punishmentFlag = forwardModelKinetics(
            X, self.tsec, self._TC, geometry=self.geometry
        )

        # 2. PHYSICS-INFORMED ML CONSTRAINTS
        # If the optimizer proposes a mathematically "fit" model that violates physical reality 
        # (e.g., degassing all gas before the experiment ends), we heavily penalize the residual.
        if self.punish_degas_early:
            punishmentFlag = (punishmentFlag * 10) + 1
        else:
            punishmentFlag = 1

        # 3. VECTORIZED TRANSFORMATIONS
        # Convert cumulative gas release into non-cumulative fractional release for each step.
        trueFracMDD = Fi_MDD[1:] - Fi_MDD[0:-1]
        trueFracMDD = torch.concat(
            (torch.unsqueeze(Fi_MDD[0], dim=0), trueFracMDD), dim=0
        )

        # Ensure correct dimensionality for 2D batch tensor operations
        if len(trueFracMDD.shape) < 2:
            trueFracMDD = torch.unsqueeze(trueFracMDD, 1)

        trueFracFi = self.trueFracFi
        moles_MDD = trueFracMDD * total_moles 

        # 4. MASK APPLICATION & MISFIT EVALUATION
        # Apply the pre-computed binary masks (from __init__) to filter out ignored/bad data steps
        # using fast matrix multiplication instead of slow iterative loops.
        
        if self.stat.lower() == "chisq":
            multiplier = 1 - torch.tile(
                self.omitValueIndices_chisq.unsqueeze(1), [1, trueFracMDD.shape[1]]
            )
            # Chi-squared: Weighted by experimental uncertainty
            misfit = torch.sum(
                multiplier * ((self.exp_moles.unsqueeze(1) - moles_MDD) ** 2) / (self.dataset.uncert.unsqueeze(1) ** 2),
                axis=0,
            )

        elif self.stat.lower() == "l2_frac":
            multiplier = 1 - torch.tile(
                self.omitValueIndices.unsqueeze(1), [1, trueFracMDD.shape[1]]
            )
            # L2 Norm (Fractional): Sum of squared errors
            misfit = torch.sum(
                (multiplier * (trueFracFi - trueFracMDD) ** 2), axis=0
            )

        elif self.stat.lower() == "percent_frac":
            multiplier = 1 - torch.tile(
                self.omitValueIndices.unsqueeze(1), [1, trueFracMDD.shape[1]]
            )
            # Format target shape and prevent divide-by-zero errors
            trueFracFi_tiled = torch.tile(trueFracFi.unsqueeze(1), [1, trueFracMDD.shape[1]])
            trueFracFi_tiled[trueFracFi_tiled == 0] = torch.min(trueFracFi_tiled[trueFracFi_tiled != 0]) * 0.1
            
            # Percentage Fractional Error
            misfit = torch.sum(
                multiplier * (torch.abs(trueFracFi_tiled - trueFracMDD)) / trueFracFi_tiled, axis=0
            )

        # Return the final residual, modified by our physical constraint penalty
        return misfit * punishmentFlag

   